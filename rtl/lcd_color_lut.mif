-- GBC LCD color LUT
-- Calculation:
-- R,G,B range 0 - 31
-- r = R * 255 / 31 (to range 0-255)
-- g = G * 255 / 31
-- b = B * 255 / 31

-- r = pow(r/255, 2.2) * 255 (pre-gamma 2.2)
-- g = pow(g/255, 2.2) * 255
-- b = pow(b/255, 2.2) * 255

-- g = ((g * 13) + (b * 3)) / 16 (mix color 13/16 + 3/16)

-- r = pow(r/255, 1/2.2 * 0.7) * 255 (final gamma 0.7)
-- g = pow(g/255, 1/2.2 * 0.7) * 255
-- b = pow(b/255, 1/2.2 * 0.7) * 255

DEPTH = 32768;
WIDTH = 24;
ADDRESS_RADIX = HEX;
DATA_RADIX = HEX;
